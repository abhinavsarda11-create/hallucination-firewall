# === Groq API Key ===
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# === Firewall config ===
# Action when risk_score >= threshold: WARN | BLOCK | REWRITE
HF_ACTION=WARN
HF_WARN_THRESHOLD=40
HF_BLOCK_THRESHOLD=75
HF_REWRITE_THRESHOLD=60

# === Retrieval index ===
FAISS_INDEX_PATH=./data/index.faiss
DOCS_PATH=./data/knowledge_docs/

# === Neo4j (optional — skip for basic demo) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_ENABLED=false

# === Server ===
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
